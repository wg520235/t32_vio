# 交叉编译工具链示例 (MIPS Linux)
# 复制此文件为 mips-linux-gnu.cmake 并修改路径

set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR mips)

# 指定交叉编译器
set(CMAKE_C_COMPILER /path/to/mips-linux-gnu-gcc)
set(CMAKE_CXX_COMPILER /path/to/mips-linux-gnu-g++)

# 指定sysroot (如果需要)
# set(CMAKE_SYSROOT /path/to/sysroot)

# 查找程序、库、头文件时不会搜索主机目录
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)

# 编译选项
set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -mips32r2 -mhard-float")
set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -mips32r2 -mhard-float")

# 链接选项
set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -static")
